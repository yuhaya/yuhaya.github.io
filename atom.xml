define(<span class="string">'DEVELOP_ENV'</span>,<span class="number">0</span>);
<span class="keyword">if</span>(DEVELOP_ENV){
	error_reporting(E_ALL);
	ini_set(<span class="string">'display_errors'</span>, <span class="number">1</span>);
}<span class="keyword">else</span>{
	ini_set(<span class="string">'display_errors'</span>, <span class="number">0</span>);
}

<span class="function"><span class="keyword">function</span> <span class="title">all_files</span><span class="params">(<span class="variable">$file_pos</span> = <span class="string">'all_file.php'</span>)</span>{</span>
	<span class="keyword">if</span>(file_exists(<span class="variable">$file_pos</span>)){
		<span class="keyword">return</span>;
	}
	<span class="variable">$file</span> = get_included_files();
	<span class="variable">$black_tip</span> = <span class="keyword">array</span>(
		<span class="string">'SplAutoloader.php'</span>
	);
	<span class="keyword">foreach</span> (<span class="variable">$file</span> <span class="keyword">as</span> <span class="variable">$k</span>=&gt;<span class="variable">$value</span>){
		<span class="keyword">foreach</span> (<span class="variable">$black_tip</span> <span class="keyword">as</span> <span class="variable">$v</span>){
			<span class="keyword">if</span>(preg_match(<span class="string">'/'</span>.<span class="variable">$v</span>.<span class="string">'/'</span>, <span class="variable">$value</span>)){
				<span class="keyword">unset</span>(<span class="variable">$file</span>[<span class="variable">$k</span>]);
			}
		}
	}
	<span class="variable">$str</span> = <span class="string">"&lt;?php\n return "</span>.var_export(<span class="variable">$file</span>,<span class="keyword">true</span>).<span class="string">";\n?&gt;"</span>;
	file_put_contents(<span class="variable">$file_pos</span>, <span class="variable">$str</span>);
}
<span class="function"><span class="keyword">function</span> <span class="title">strip_whitespace</span><span class="params">(<span class="variable">$content</span>)</span> {</span>
    <span class="variable">$stripStr</span> = <span class="string">''</span>;
    <span class="variable">$tokens</span> =   token_get_all (<span class="variable">$content</span>);
    <span class="variable">$last_space</span> = <span class="keyword">false</span>;
    <span class="keyword">for</span> (<span class="variable">$i</span> = <span class="number">0</span>, <span class="variable">$j</span> = count (<span class="variable">$tokens</span>); <span class="variable">$i</span> &lt; <span class="variable">$j</span>; <span class="variable">$i</span>++){
        <span class="keyword">if</span> (is_string (<span class="variable">$tokens</span>[<span class="variable">$i</span>])){
            <span class="variable">$last_space</span> = <span class="keyword">false</span>;
            <span class="variable">$stripStr</span> .= <span class="variable">$tokens</span>[<span class="variable">$i</span>];
        }
        <span class="keyword">else</span>{
            <span class="keyword">switch</span> (<span class="variable">$tokens</span>[<span class="variable">$i</span>][<span class="number">0</span>]){
                <span class="keyword">case</span> T_COMMENT:
                <span class="keyword">case</span> T_DOC_COMMENT:
                <span class="keyword">case</span> T_OPEN_TAG;
                <span class="keyword">case</span> T_CLOSE_TAG;
                    <span class="keyword">break</span>;
                <span class="keyword">case</span> T_WHITESPACE:
                    <span class="keyword">if</span> (!<span class="variable">$last_space</span>){
                        <span class="variable">$stripStr</span> .= <span class="string">' '</span>;
                        <span class="variable">$last_space</span> = <span class="keyword">true</span>;
                    }
                    <span class="keyword">break</span>;
                <span class="keyword">default</span>:
                    <span class="variable">$last_space</span> = <span class="keyword">false</span>;
                    <span class="variable">$stripStr</span> .= <span class="variable">$tokens</span>[<span class="variable">$i</span>][<span class="number">1</span>];
            }
        }
    }
    <span class="keyword">return</span> <span class="variable">$stripStr</span>;
}
<span class="function"><span class="keyword">function</span> <span class="title">complie</span><span class="params">(<span class="variable">$arr_file</span>,<span class="variable">$file_name</span>,<span class="variable">$extra_file</span>)</span>{</span>
	<span class="keyword">if</span>(!file_exists(<span class="variable">$file_name</span>)){
		file_put_contents(<span class="variable">$file_name</span>, <span class="string">''</span>);
	}
	<span class="keyword">if</span>(file_get_contents(<span class="variable">$file_name</span>) != <span class="string">''</span>){
		file_put_contents(<span class="variable">$file_name</span>, <span class="string">''</span>);
	}
	<span class="keyword">if</span>(file_get_contents(<span class="variable">$extra_file</span>) != <span class="string">''</span>){
		file_put_contents(<span class="variable">$extra_file</span>, <span class="string">''</span>);
	}
	<span class="variable">$run_file</span> = <span class="keyword">array</span>(
			<span class="variable">$file_name</span>,
			<span class="variable">$extra_file</span>
		);
	<span class="keyword">foreach</span> (<span class="variable">$arr_file</span> <span class="keyword">as</span> <span class="variable">$key</span> =&gt; <span class="variable">$value</span>) {
		<span class="keyword">if</span>(in_array(<span class="variable">$value</span>, <span class="variable">$run_file</span>)){
			<span class="keyword">continue</span>;
		}
		<span class="variable">$res</span> = strip_whitespace(file_get_contents(<span class="variable">$value</span>));
		<span class="variable">$res</span> = preg_replace(<span class="string">'/^\s*/'</span>,<span class="string">''</span>, <span class="variable">$res</span>);<span class="comment">//匹配开始空格</span>
		<span class="variable">$dir</span> = str_replace(DIRECTORY_SEPARATOR.basename(<span class="variable">$value</span>), <span class="string">''</span>, <span class="variable">$value</span>);
		<span class="variable">$res</span> = preg_replace(<span class="string">'/__DIR__/'</span>,<span class="string">"'"</span>.<span class="variable">$dir</span>.<span class="string">"'"</span>, <span class="variable">$res</span>);<span class="comment">//匹配开始空格</span>
		<span class="variable">$position</span> = stripos(<span class="variable">$res</span>,<span class="string">'namespace'</span>);
		<span class="keyword">if</span>(<span class="variable">$position</span> === <span class="number">0</span>){
			file_put_contents(<span class="variable">$file_name</span>, <span class="string">"\n"</span>.<span class="variable">$res</span>,FILE_APPEND);
		}<span class="keyword">else</span>{
			file_put_contents(<span class="variable">$extra_file</span>, <span class="variable">$value</span>.<span class="string">"\n"</span>,FILE_APPEND);
		}
	}

	<span class="variable">$complie</span> = file_get_contents(<span class="variable">$file_name</span>);
	<span class="variable">$str</span> = <span class="string">"&lt;?php \n"</span>.<span class="variable">$complie</span>.<span class="string">"\n?&gt;"</span>;
	file_put_contents(<span class="variable">$file_name</span>, <span class="variable">$str</span>);
}
<span class="function"><span class="keyword">function</span> <span class="title">load_complie</span><span class="params">(<span class="variable">$complie</span> = <span class="string">"complie.php"</span>,<span class="variable">$all_file</span> = <span class="string">'all_file.php'</span>,<span class="variable">$extra_file</span> = <span class="string">'extra.txt'</span>)</span>{</span>
	<span class="keyword">if</span>(file_exists(<span class="variable">$complie</span>)){
		<span class="keyword">require</span> <span class="variable">$complie</span>;
	}<span class="keyword">elseif</span>(file_exists(<span class="variable">$all_file</span>)){
		<span class="variable">$file_arr</span> = <span class="keyword">require</span> <span class="variable">$all_file</span>;
		complie(<span class="variable">$file_arr</span>,<span class="variable">$complie</span>,<span class="variable">$extra_file</span>);
	}
}

<span class="keyword">if</span>(!DEVELOP_ENV){
	load_complie(__ROOT__.<span class="string">'/cache/complie.php'</span>,__ROOT__.<span class="string">'/cache/all_file.php'</span>,__ROOT__.<span class="string">'/cache/extra.txt'</span>);
}

<span class="comment">// Setup autoloading</span>
<span class="keyword">require</span> <span class="string">'init_autoloader.php'</span>;

<span class="comment">// Run the application!</span>
Zend\Mvc\Application::init(<span class="keyword">require</span> <span class="string">'config/application.config.php'</span>)-&gt;run();

all_files(__ROOT__.<span class="string">'/cache/all_file.php'</span>);
</pre></td></tr></table></figure>


<ul>
<li><h4 id="all_files">all_files</h4>
<blockquote>
<p>获取所有需要加载的文件</p>
</blockquote>
</li>
<li><h4 id="strip_whitespace">strip_whitespace</h4>
<blockquote>
<p>压缩php文件</p>
</blockquote>
</li>
<li><h4 id="complie">complie</h4>
<blockquote>
<p>合并php文件</p>
</blockquote>
</li>
<li><h4 id="load_complie">load_complie</h4>
<blockquote>
<p>加载合并文件</p>
</blockquote>
</li>
</ul>
]]></content>
    
    
