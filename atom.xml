                    [Zend\Authentication\Adapter\DbTable\<span class="keyword">Exception</span>\RuntimeException] =&gt; /Applications/XAMPP/xamppfiles/htdocs/zend/vendor/ZF2/library/Zend/Authentication/Adapter/DbTable/<span class="keyword">Exception</span>/RuntimeException.php
