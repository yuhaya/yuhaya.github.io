                    [Zend\Authentication\Adapter\<span class="keyword">Exception</span>\RuntimeException] =&gt; /Applications/XAMPP/xamppfiles/htdocs/zend/vendor/ZF2/library/Zend/Authentication/Adapter/<span class="keyword">Exception</span>/RuntimeException.php
                    [Zend\Authentication\Adapter\<span class="keyword">Exception</span>\UnexpectedValueException] =&gt; /Applications/XAMPP/xamppfiles/htdocs/zend/vendor/ZF2/library/Zend/Authentication/Adapter/<span class="keyword">Exception</span>/UnexpectedValueException.php
