5
</pre></td><td class="code"><pre><span class="variable">$loader</span> = \Zend\Loader\AutoloaderFactory::getRegisteredAutoloaders();
        
<span class="keyword">echo</span> <span class="string">"&lt;pre&gt;"</span>;
        
print_r(<span class="variable">$loader</span>);
</pre></td></tr></table></figure>


